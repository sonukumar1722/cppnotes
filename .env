# .env.example — copy to .env and fill in

# ── Application ──────────────────────────────
APP_ENV=development           # development | production
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_URL=http://localhost:5173

# ── Security ─────────────────────────────────
JWT_SECRET_KEY=CHANGE_THIS_TO_64_CHAR_RANDOM_STRING
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# ── Database ─────────────────────────────────
DATABASE_URL=postgresql+asyncpg://cppnote:password@localhost:5432/cppnote_db
POSTGRES_USER=cppnote
POSTGRES_PASSWORD=password
POSTGRES_DB=cppnote_db

# ── Execution ─────────────────────────────────
EXECUTOR_IMAGE=cpp-executor:latest
EXEC_TIMEOUT_SECONDS=10
EXEC_MEMORY_LIMIT=128m
EXEC_CPU_LIMIT=0.5
EXEC_PID_LIMIT=64
EXEC_TMP_SIZE=64m

# ── File Upload ───────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=10

# ── Default User (seeded on first run) ───────
DEFAULT_USERNAME=admin
DEFAULT_EMAIL=admin@localhost
DEFAULT_PASSWORD=CHANGE_THIS_PASSWORD